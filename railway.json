{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "corepack pnpm --filter @social-agents/api build",
    "watchPatterns": [
      "/apps/api/**",
      "/packages/agents/**",
      "/packages/shared/**",
      "/packages/remotion/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/railway.json"
    ]
  },
  "deploy": {
    "startCommand": "corepack pnpm --filter @social-agents/api start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
